---
interface Props {
  icon: any;
  title: string;
  description: string;
}

const { icon: Icon, title, description } = Astro.props;
---

<div class="bg-white rounded-lg p-6 border border-border shadow-sm hover:shadow-md hover:border-primary/20 transition-all duration-300">
  <div class="mb-4">
    <div class="w-12 h-12 bg-accent/20 rounded-lg flex items-center justify-center">
      <Icon class="w-6 h-6 text-accent" />
    </div>
  </div>

  <h3 class="text-lg font-semibold text-foreground mb-3">{title}</h3>

  <p class="text-muted-foreground text-sm mb-4 leading-relaxed">{description}</p>

  <a href="/#contact" class="text-accent font-semibold text-sm hover:opacity-80 transition-opacity">
    Enquire →
  </a>
</div>