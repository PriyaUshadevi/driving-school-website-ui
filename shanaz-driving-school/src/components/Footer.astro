---
import B12Link from './B12Link.astro';

const footerLinks = [
  { name: "Services", href: "/#services" },
  { name: "Reviews", href: "/#reviews" },
  { name: "About", href: "/#about" },
  { name: "Contact", href: "/#contact" },
  { name: "Directions", href: "/#directions" }
];
---

<footer class="bg-primary text-primary-foreground py-12">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <div>
        <h3 class="font-bold text-lg mb-4">Shanaz Driving School</h3>
        <p class="text-sm opacity-90">Professional driving lessons in Halifax with a highly rated instructor.</p>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          {footerLinks.map((link) => (
            <li>
              <a href={link.href} class="opacity-90 hover:opacity-100 transition-opacity">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Contact</h4>
        <div class="text-sm space-y-2 opacity-90">
          <p class="font-medium">Phone</p>
          <p>
            <a href="tel:+447815671794" class="hover:opacity-100 transition-opacity">
              07815 671 794
            </a>
          </p>
        </div>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Hours</h4>
        <div class="text-sm space-y-1 opacity-90">
          <p>Monday - Friday: 12am - 11:59pm</p>
          <p>Saturday: Closed</p>
          <p>Sunday: Closed</p>
        </div>
      </div>
    </div>

    <div class="border-t border-primary-foreground/20 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm opacity-75">© 2026 Shanaz Driving School. All rights reserved.</p>
      <B12Link />
    </div>
  </div>
</footer>